{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2021",
    "lib": ["dom", "dom.iterable", "esnext"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@agent-os/contracts": ["../../packages/contracts/src/index.ts"],
      "@agent-os/contracts/*": ["../../packages/contracts/src/*"],
      "@agent-os/core": ["../../packages/core/src/index.ts"],
      "@agent-os/core/*": ["../../packages/core/src/*"],
      "@agent-os/platform": ["../../packages/platform/src/index.ts"],
      "@agent-os/platform/*": ["../../packages/platform/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
