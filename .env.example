# Local vault root (Obsidian PARA checkout)
# Vault git push/pull is OUT OF SCOPE for this app — handled by an external sync system.
VAULT_PATH=/Users/mg/Obsidian

# App data directory (audit.jsonl; default ~/.local/share/agent-os)
# AGENT_OS_DATA_PATH=/Users/mg/.local/share/agent-os

# MongoDB (required) — database name in URI path (collections: foods, meals, goals)
# MONGODB_URI=mongodb://localhost:27017/nutrition-tracker
# Docker image: embedded mongod on 127.0.0.1 (set automatically in docker-entrypoint.sh)
# External DB: MONGODB_URI=... and EMBEDDED_MONGO=false
# One-shot legacy JSON import only: LEGACY_NUTRITION_IMPORT_DIR=~/.local/share/agent-os/nutrition npm run migrate:nutrition

# Cursor SDK for /assistant chat (composer-2.5 via local agent + MCP tools)
# CURSOR_API_KEY=cursor_...
# CURSOR_ASSISTANT_MODEL=composer-2.5
# CURSOR_AGENT_CWD=/Users/mg/Project/agent-os   # defaults to process.cwd() (/app in Docker)

# Assistant OAuth redirect host — used when calendar tools run via MCP (no HTTP request).
# Default localhost:3003 (dev). In prod set to the public host, e.g. personal-dashboard.lumen-dev.com.
# Ignored entirely if GOOGLE_OAUTH_REDIRECT_URI is set.
# ASSISTANT_OAUTH_HOST=personal-dashboard.lumen-dev.com

# Assistant tool-routing policy — set PER CHAT REQUEST by the app on the MCP child
# process. Do NOT set these globally (e.g. in docker-compose); a global value
# overrides per-request routing. Listed here for reference only.
# ASSISTANT_ROUTING_MODE=none        # none | soft | hard
# ASSISTANT_ALLOWED_TOOLS=tool_a,tool_b   # enforced only when ROUTING_MODE=hard
# ASSISTANT_PREFERRED_TOOLS=tool_a,tool_b
# ASSISTANT_COMMAND_ID=general

# Legacy Gemini (removed from /api/chat — kept only if you still use it elsewhere)
# GEMINI_API_KEY=

# Timezone for nutrition "today" (default Asia/Jakarta)
# TZ=Asia/Jakarta

# Dev server port (see package.json)
# PORT=3003

# Google Calendar (read-only OAuth) — see vault runbook-google-calendar-connect
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=   # optional; default from request host
# TOKEN_ENCRYPTION_KEY=        # openssl rand -base64 32 (shared by all integrations)
# OAUTH_STATE_SECRET=          # openssl rand -base64 32 (shared by all integrations)

# ClickUp (two-way) — /tasks surface + Home "due today" widget
# Default path = Personal API Token (no admin, no app registration):
#   only requires TOKEN_ENCRYPTION_KEY above. Paste the pk_ token in the
#   Settings → Integrations page (ClickUp → Settings → Apps → API Token).
#
# Optional OAuth "Connect" button (needs workspace admin to register an app):
# Redirect URL must be {host}/api/integrations/clickup/callback
# CLICKUP_OAUTH_CLIENT_ID=
# CLICKUP_OAUTH_CLIENT_SECRET=
# CLICKUP_OAUTH_REDIRECT_URI=   # optional; default from request host
#
# Sprint grouping: comma-separated ClickUp folder names to treat as sprints
# (case-insensitive). Lists in these folders are pulled into a dedicated
# "Sprints" section at the top of the /tasks list view.
# CLICKUP_SPRINT_FOLDERS=Sprint Folder,Dev Sprints

# WAHA → POST /api/webhooks/whatsapp (HMAC on raw body)
# Must match session config.webhooks[].hmac.key in WAHA
# WAHA_WEBHOOK_SECRET=your-secret-key
# WAHA_BASE_URL=http://localhost:3000
# WAHA_API_KEY=your-waha-api-key
# WAHA_SESSION=default
# Comma-separated JIDs allowed to capture (solo-user guard)
# WHATSAPP_ALLOWED_JIDS=628123456789@c.us
# WHATSAPP_ACK_MESSAGE=Saved to Inbox

# Dev/test only — base URL for scripts/waha-webhook-smoke.mjs (not used at runtime)
# SMOKE_BASE_URL=http://localhost:3003

# Site password gate — active when DEV_PREVIEW_PASSWORD is set (no separate enable flag).
# Unset DEV_PREVIEW_PASSWORD to disable. Never use NEXT_PUBLIC_* for these values.
# DEV_PREVIEW_PASSWORD=
# DEV_PREVIEW_SECRET=          # openssl rand -base64 24 (16+ chars required)
# DEV_PREVIEW_COOKIE_MAX_AGE=604800
