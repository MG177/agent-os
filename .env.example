# Local vault root (Obsidian PARA checkout)
# Vault git push/pull is OUT OF SCOPE for this app — handled by an external sync system.
VAULT_PATH=/Users/mg/Obsidian

# App data directory (audit.jsonl; default ~/.local/share/agent-os)
# AGENT_OS_DATA_PATH=/Users/mg/.local/share/agent-os

# MongoDB (required) — database name in URI path (collections: foods, meals, goals)
# MONGODB_URI=mongodb://localhost:27017/nutrition-tracker
# Docker image: embedded mongod on 127.0.0.1 (set automatically in docker-entrypoint.sh)
# External DB: MONGODB_URI=... and EMBEDDED_MONGO=false
# One-shot legacy JSON import only: LEGACY_NUTRITION_IMPORT_DIR=~/.local/share/agent-os/nutrition npm run migrate:nutrition

# Cursor SDK for /assistant chat (composer-2.5 via local agent + MCP tools)
# CURSOR_API_KEY=cursor_...
# CURSOR_ASSISTANT_MODEL=composer-2.5
# CURSOR_AGENT_CWD=/Users/mg/Project/agent-os

# Legacy Gemini (removed from /api/chat — kept only if you still use it elsewhere)
# GEMINI_API_KEY=

# Timezone for nutrition "today" (default Asia/Jakarta)
# TZ=Asia/Jakarta

# Dev server port (see package.json)
# PORT=3003

# Google Calendar (read-only OAuth) — see vault runbook-google-calendar-connect
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=   # optional; default from request host
# TOKEN_ENCRYPTION_KEY=        # openssl rand -base64 32
# OAUTH_STATE_SECRET=          # openssl rand -base64 32

# WAHA → POST /api/webhooks/whatsapp (HMAC on raw body)
# Must match session config.webhooks[].hmac.key in WAHA
# WAHA_WEBHOOK_SECRET=your-secret-key
# WAHA_BASE_URL=http://localhost:3000
# WAHA_API_KEY=your-waha-api-key
# WAHA_SESSION=default
# Comma-separated JIDs allowed to capture (solo-user guard)
# WHATSAPP_ALLOWED_JIDS=628123456789@c.us
# WHATSAPP_ACK_MESSAGE=Saved to Inbox
