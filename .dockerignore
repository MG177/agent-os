# dependencies — reinstalled in-image via pnpm (nested across the workspace)
**/node_modules
.pnp
.pnp.*

# build output — rebuilt in-image
**/.next
**/.turbo
**/out
**/build

# env / secrets — provided at runtime via compose, never baked in
**/.env
**/.env.local
**/.env.*.local

# vcs & ci
.git
.gitignore
.github

# typescript incremental
**/*.tsbuildinfo
**/next-env.d.ts

# scratch / throwaway mockups
**/temp

# docs & design references (not needed at runtime)
docs
README.md
AGENTS.md
CLAUDE.md
Design System — Nutrition & PARA.html
deploy

# editor / os
.DS_Store
.vscode
.idea

# docker (avoid recursive copy of build files into context)
Dockerfile
docker-compose*.yml
.dockerignore
